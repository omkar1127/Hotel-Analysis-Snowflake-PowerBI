Medellion Architecture Implementation In SnowFlake

CREATE DATABASE hotel_db;

CREATE OR REPLACE FILE FORMAT FF_CSV
    TYPE = 'CSV'
    FIELD_OPTIONALLY_ENCLOSED_BY = '"'
    SKIP_HEADER = 1
    NULL_IF = ('NULL','null','')

-- Staging Area
CREATE OR REPLACE STAGE HOTEL_BOOKINGS_STAG
    FILE_FORMAT = FF_CSV;

-- Bronze LABEL
DROP TABLE IF EXISTS BRONZE_HOTEL_BOOKING;
CREATE TABLE BRONZE_HOTEL_BOOKING(
    booking_id STRING,
    hotel_id STRING,
    hotel_city STRING,
    customer_id STRING,
    customer_name STRING,
    customer_email STRING,
    check_in_date STRING,
    check_out_date STRING,
    room_type STRING,
    num_guests STRING,
    total_amount STRING,
    currency STRING,
    booking_status STRING
);


-- checking if file is present in the staging area 
LIST @HOTEL_BOOKINGS_STAG;


COPY INTO BRONZE_HOTEL_BOOKING
FROM @HOTEL_BOOKINGS_STAG
FILE_FORMAT = (FORMAT_NAME = FF_CSV)
ON_ERROR = 'CONTINUE';

-- check if data loaded into table

SELECT * FROM BRONZE_HOTEL_BOOKING
LIMIT 10;

-- SILVER LAYER
DROP TABLE IF EXISTS SILVER_HOTEL_BOOKING;
CREATE TABLE SILVER_HOTEL_BOOKING(
    booking_id VARCHAR,
    hotel_id VARCHAR,
    hotel_city VARCHAR,
    customer_id VARCHAR,
    customer_name VARCHAR,
    customer_email VARCHAR,
    check_in_date DATE,
    check_out_date DATE,
    room_type VARCHAR,
    num_guests INTEGER,
    total_amount FLOAT,
    currency VARCHAR,
    booking_status VARCHAR
);

-- checking for invalid email
SELECT customer_email
FROM BRONZE_HOTEL_BOOKING
WHERE NOT (customer_email LIKE '%@%.%')
    OR customer_email IS NULL;

-- checking invalid total_amount
SELECT total_amount
FROM BRONZE_HOTEL_BOOKING
WHERE total_amount < 0;

-- checking if the valid dates are present
SELECT check_in_date, check_out_date
FROM BRONZE_HOTEL_BOOKING
WHERE TRY_TO_DATE(check_out_date) < TRY_TO_DATE(check_in_date);

-- checking for valid booking status
SELECT DISTINCT BOOKING_STATUS
FROM BRONZE_HOTEL_BOOKING;

INSERT INTO SILVER_HOTEL_BOOKING
SELECT 
    booking_id,
    hotel_id,
    INITCAP(TRIM(hotel_city)) as hotel_city,
    customer_id,
    INITCAP(customer_name) as customer_name,
    CASE 
        WHEN customer_email LIKE '%@%.%' THEN LOWER(TRIM(customer_email)) ELSE NULL
    END AS customer_email,
    TRY_TO_DATE(NULLIF(check_in_date, '')) AS check_in_date,
    TRY_TO_DATE(NULLIF(check_out_date, '')) AS check_out_date,
    room_type,
    num_guests,
    ABS(TRY_TO_NUMBER(total_amount)) AS total_amount,
    currency,
    CASE 
        WHEN LOWER(booking_status) in ('confirmeeed','confirmeed') THEN 'Confirmed' ELSE booking_status
    END as booking_status
FROM BRONZE_HOTEL_BOOKING
WHERE
    TRY_TO_DATE(check_in_date) IS NOT NULL
    AND TRY_TO_DATE(check_out_date) IS NOT NULL
    AND TRY_TO_DATE(check_out_date) >= TRY_TO_DATE(check_in_date);


-- checking the inserted rows
SELECT * FROM SILVER_HOTEL_BOOKING LIMIT 10;

DROP TABLE IF EXISTS GOLD_AGG_DAILY_BOOKING;
CREATE TABLE GOLD_AGG_DAILY_BOOKING AS
SELECT
    check_in_date as date,
    COUNT(*) AS total_booking,
    SUM(total_amount) as total_revenue
FROM SILVER_HOTEL_BOOKING
GROUP BY check_in_date
ORDER BY date;

DROP TABLE IF EXISTS GOLD_AGG_HOTEL_CITY_SALES;
CREATE TABLE GOLD_AGG_HOTEL_CITY_SALES AS
SELECT 
    hotel_city,
    SUM(total_amount) as total_revenue
FROM SILVER_HOTEL_BOOKING
GROUP BY hotel_city
ORDER BY total_revenue DESC;

--Creating the clean gold table
DROP TABLE IF EXISTS GOLD_BOOKING_CLEAN;
CREATE TABLE GOLD_BOOKING_CLEAN AS
SELECT
    booking_id,
    hotel_id,
    hotel_city,
    customer_id,
    customer_name,
    customer_email,
    check_in_date,
    check_out_date,
    room_type,
    num_guests,
    total_amount,
    currency,
    booking_status
FROM SILVER_HOTEL_BOOKING;


-- checking out the tables
SELECT * FROM GOLD_AGG_DAILY_BOOKING LIMIT 10;

SELECT * FROM GOLD_AGG_HOTEL_CITY_SALES LIMIT 10;

SELECT * FROM GOLD_BOOKING_CLEAN LIMIT 10;

